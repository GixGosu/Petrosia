# Petrosia Configuration
# =====================
# No API keys required for local-only use with Ollama!
# Just run: docker-compose up

# Database (defaults work with docker-compose)
DATABASE_URL=postgresql+asyncpg://petrosia:petrosia123@db:5432/petrosia
DATABASE_URL_SYNC=postgresql://petrosia:petrosia123@db:5432/petrosia

# Default LLM Provider
# Ollama runs locally in Docker — no API key needed
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://ollama:11434

# Optional: Cloud LLM Providers
# Uncomment and add your API key to use cloud providers instead
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# MISTRAL_API_KEY=...

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (comma-separated list in JSON format)
# Default: localhost only. Set to ["*"] if behind a reverse proxy
CORS_ORIGINS=["http://localhost:8000", "http://localhost:3000"]

# RAG Settings
MAX_CONTEXT_ARTICLES=5
SIMILARITY_THRESHOLD=0.7
RAG_SIMILARITY_THRESHOLD=0.3

# Embedding Model (do not change unless you reset the database)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
